# Respan credentials — grab from https://respan.ai/platform/api/api-keys
RESPAN_API_KEY=sk-respan-...
RESPAN_ORG_ID=org_...

# Gateway base URL — the OpenAI-compatible endpoint
RESPAN_BASE_URL=https://api.respan.ai/api

# Default models routed through Respan Gateway
ARENA_DEFAULT_MODEL=gpt-4o-mini
ARENA_JUDGE_MODEL=claude-haiku-4-5
ARENA_OPTIMIZER_MODEL=claude-sonnet-4-6

# Storage — leave unset for SQLite at ./arena.db
# DATABASE_URL=postgresql+psycopg://arena:arena@localhost:5432/arena

# Optional: disable Respan logging for sensitive eval cases
# ARENA_DISABLE_LOG=false
